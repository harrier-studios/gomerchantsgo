<form class="merchants-config">
  <div class="form-group">
    <label class="checkbox">
      <input type="checkbox" name="enabled" {{checked merchant.enabled}} />
      {{localize "MERCHANTS.EnabledLabel"}}
    </label>
    <p class="hint">{{localize "MERCHANTS.EnabledHint"}}</p>
  </div>
  <div class="form-group">
    <label>{{localize "MERCHANTS.Welcome"}}</label>
    <textarea name="welcomeMessage" rows="3" placeholder="">{{merchant.welcomeMessage}}</textarea>
    <p class="hint">{{localize "MERCHANTS.WelcomeHint"}}</p>
  </div>
  <div class="form-group">
    <label>{{localize "MERCHANTS.DefaultPriceHint"}}</label>
    <input type="number" name="defaultPrice" min="0" step="0.01" value="{{merchant.defaultPrice}}" />
  </div>
  <button type="submit" class="button">
    <i class="fas fa-save"></i> {{localize "MERCHANTS.Save"}}
  </button>
</form>
